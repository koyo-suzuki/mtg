{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["node", "python"]
    },
    "watchPatterns": ["local-app-v2/**"]
  },
  "deploy": {
    "startCommand": "cd local-app-v2 && npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
